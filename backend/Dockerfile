# готовый образ Python 3.11
# slim — урезанная версия без лишних пакетов (меньше размер образа)
FROM python:3.11-slim

# Рабочая директория внутри контейнера
# Все последующие команды выполняются относительно /app
WORKDIR /app

# Устанавливаем Poetry глобально в контейнере
RUN pip install --no-cache-dir poetry==1.8.0

# Копируем ТОЛЬКО файл зависимостей (не весь код!)
# Это важно для кеширования: Docker кеширует слои.
# Если код изменился, но pyproject.toml нет — Docker использует кеш для этого шага.
# Пересборка зависимостей происходит только когда меняется pyproject.toml.
COPY pyproject.toml ./

# Устанавливаем зависимости
# virtualenvs.create false — не создаём виртуальное окружение (не нужно в контейнере)
# --no-interaction — без интерактивных вопросов
# --no-ansi — без цветного вывода (чище в логах)
# --no-root — не устанавливать сам пакет (только зависимости)
RUN poetry config virtualenvs.create false \
    && poetry install --no-interaction --no-ansi --no-root

# Теперь копируем весь код
# Делается ПОСЛЕ установки зависимостей — чтобы изменение кода не инвалидировало кеш зависимостей
COPY . .

# Команда запуска контейнера
# sh -c позволяет выполнить несколько команд последовательно
# 1. alembic upgrade head — применяем все миграции (создаём таблицы)
# 2. uvicorn — запускаем FastAPI сервер
#    --host 0.0.0.0  — слушаем на всех интерфейсах (не только localhost)
#    --port 8000     — порт внутри контейнера
CMD ["sh", "-c", "alembic upgrade head && uvicorn app.main:application --host 0.0.0.0 --port 8000"]