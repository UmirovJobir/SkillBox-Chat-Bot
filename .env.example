# ─── PostgreSQL ───
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# DATABASE_URL — строка подключения к БД
# Формат: postgresql://пользователь:пароль@хост:порт/имя_бд
# "postgres" — это имя сервиса в docker-compose, не localhost!
DATABASE_URL=

# ─── JWT ───
# SECRET_KEY — секрет для подписи токенов. Меняйте в продакшене!
SECRET_KEY=
ALGORITHM=
# Токен действует 10080 минут = 7 дней
ACCESS_TOKEN_EXPIRE_MINUTES=

# ─── Telegram ───
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=

# Адрес backend внутри Docker сети (имя сервиса = "backend")
BACKEND_URL=

# ─── Настройки приложения ───
# Сколько раз нужно выполнить привычку для выработки (правило 21 дня)
HABIT_TARGET_DAYS=

# Часовой пояс для уведомлений (используется ботом и бэкендом)
TIMEZONE=